extends layout

block content
    h1 Explorar Publicaciones

    
    form.search-form(action="/" method="GET")
        input.ink-input(
            type="text" 
            name="search" 
            placeholder="Buscar por título o descripción..." 
            value=busqueda
        )
        input.ink-btn(type="submit" value="Buscar")
        if busqueda
            a.ink-link-clear(href="/") Limpiar filtros

    // Galería de Imágenes
    if fotos && fotos.length > 0
        div.galeria
            each foto in fotos
                div.ink-box.tarjeta-foto
                    h3 #{foto.title}
                    img.ink-img(src=foto.file_path, alt=foto.title)
                    
                    if foto.description
                        p.foto-descripcion #{foto.description}
                        
                    p.foto-licencia
                        strong Licencia: 
                        span(class=foto.license === 'free' ? 'licencia-free' : 'licencia-premium') #{foto.license}
                        
                    if foto.watermark_text
                        p.foto-firma
                            small Firma: #{foto.watermark_text}
                            
                    div.tarjeta-footer
                        a.ink-btn(href=`/post/${foto.id}`) Ver detalles y comentarios
    else
        if busqueda
            p.no-results No se encontraron trazos ni resultados para "#{busqueda}".
        else
            p.no-results No hay apuntes ni publicaciones disponibles en este momento.