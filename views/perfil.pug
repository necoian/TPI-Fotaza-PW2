extends layout

block content
  .container.ink-profile-container
    
    .perfil-header.ink-profile-header
      
      .avatar.ink-profile-avatar-box
        if perfilUsuario.avatar_url && perfilUsuario.avatar_url.trim() !== ''
          img.ink-profile-avatar-img(src=perfilUsuario.avatar_url, alt=perfilUsuario.username)
        else
          .ink-profile-avatar-placeholder
            | #{perfilUsuario.username.charAt(0).toUpperCase()}
      
      h1.ink-profile-title #{perfilUsuario.username}

      .stats.ink-profile-stats
        
        .ink-profile-stat-block
          .ink-profile-stat-number #{seguidoresContador}
          .ink-profile-stat-interactive(onclick=`mostrarLista(${perfilUsuario.id}, 'seguidores')`) Seguidores
          
          .ink-profile-dropdown(id="lista-seguidores")
            ul.ink-profile-dropdown-list(id="contenido-lista-seguidores")
        
        .ink-profile-stat-block
          .ink-profile-stat-number #{seguidosContador}
          .ink-profile-stat-interactive(onclick=`mostrarLista(${perfilUsuario.id}, 'seguidos')`) Seguidos
          
          .ink-profile-dropdown(id="lista-seguidos")
            ul.ink-profile-dropdown-list(id="contenido-lista-seguidos")
        
        .ink-profile-stat-block
          .ink-profile-stat-number #{postsUsuario.length}
          .ink-profile-stat-text Publicaciones

      if usuarioLogueado && usuarioLogueado.id !== perfilUsuario.id
        form.ink-profile-follow-form(action=`/user/follow/${perfilUsuario.id}`, method="POST")
          if loEstoySiguiendo
            button.ink-btn.ink-profile-btn-unfollow(type="submit") 
              | Dejar de seguir
          else
            button.ink-btn.ink-profile-btn-follow(type="submit") 
              | Seguir

    .galeria.ink-profile-galeria
      each post in postsUsuario
        .ink-profile-post-block
          if post.Images && post.Images.length > 0
            a(href=`/post/${post.id}`)
              img.ink-profile-post-img(src=post.Images[0].file_path)
          else
            .ink-profile-post-placeholder 
              | Sin imagen

          if usuarioLogueado && usuarioLogueado.id === perfilUsuario.id
            form.ink-profile-form-delete(action=`/post/${post.id}/eliminar`, method="POST", onsubmit="return confirm('¿Seguro que querés borrar esta publicación? This action cannot be undone.');")
              button.ink-btn.ink-profile-btn-delete(type="submit")
                | Borrar

  script.
    async function mostrarLista(userId, tipo) {
        const idContenedor = `lista-${tipo}`;
        const idLista = `contenido-lista-${tipo}`;
        const contenedor = document.getElementById(idContenedor);
        const lista = document.getElementById(idLista);
        
        if (contenedor.style.display === 'block') {
            contenedor.style.display = 'none';
            return;
        }

        try {
            const response = await fetch(`/user/lista/${userId}/${tipo}`);
            const usuarios = await response.json();

            if (usuarios.length > 0) {
                lista.innerHTML = usuarios.map(u => `<li>@${u}</li>`).join('');
            } else {
                lista.innerHTML = '<li>Ninguno</li>';
            }
            contenedor.style.display = 'block';
        } catch (error) {
            console.error('Error al cargar la lista:', error);
        }
    }