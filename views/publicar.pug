extends layout

block content
    .ink-form-container
        .ink-box.ink-form-card
            h1 Crear nueva publicación
            
            if error
                p.ink-error #{error}
                
            form.ink-form(action='/post/crear' method='post' enctype='multipart/form-data')
                .form-group
                    label(for='title') Título:
                    input.ink-input(type='text' name='title' id='title' value=(datosCompletados ? datosCompletados.title : '') required)
                
                .form-group
                    label(for='description') Descripción:
                    textarea.ink-input(name='description' id='description' rows="4" required) #{datosCompletados ? datosCompletados.description : ''} 
                
                .form-group
                    label(for='license') Licencia:
                    select.ink-input(name='license' id='license' required)
                        option(value='free') Libre (Sin Copyright / Pública)
                        option(value='copyright') Con Copyright
                
                .form-group
                    label(for='watermarkText') Texto marca de agua:
                    input.ink-input(type='text' name='watermarkText' id='watermarkText' value=(datosCompletados ? datosCompletados.watermarkText : '') required)
                
                
                .form-group(style="margin-top: 15px; margin-bottom: 20px;")
                    label(style="display: block; margin-bottom: 8px;") Opciones de interacción:
                    .comentario-item-ink(style="display: flex; align-items: center; gap: 12px; padding: 10px; border: 1px dashed var(--ink-blue); border-radius: 4px; background: rgba(26,58,108,0.03); width: fit-content; cursor: pointer;")
                        input(type='checkbox' name='comments_open' id='comments_open' checked=(datosCompletados ? (datosCompletados.comments_open === 'on' || datosCompletados.comments_open === true) : true) style="accent-color: var(--ink-blue); width: 18px; height: 18px; cursor: pointer;")
                        label(for='comments_open' style="cursor: pointer; margin-bottom: 0; font-weight: bold; font-family: 'Kalam', cursive; font-size: 1.05rem;") Habilitar la caja de comentarios
                
                .form-group
                    label(for='imageFile') Seleccionar Imagen:
                    input.ink-input(type='file' name='imageFile' id='imageFile' accept='image/*' required)
                
                div(style="text-align: right; margin-top: 10px;")
                    input.ink-btn(type='submit' value='Subir Publicación')